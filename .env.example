# Copy to apps/api/.env for the API process (do not commit real secrets).

# --- API ---
API_HOST=127.0.0.1
API_PORT=8000

# --- Postgres (hosted — Render / Neon / etc.; use +psycopg for SQLAlchemy 2 + psycopg3) ---
# No local Docker compose in this repo; point at your deployed database.
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@YOUR_HOST/sourcebook

# --- Redis (hosted — Upstash / Render / etc.; queue + rate limits) ---
REDIS_URL=redis://default:PASSWORD@YOUR_HOST:6379

# --- Auth ---
JWT_SECRET=dev-only-change-me-sourcebook

# --- OpenAI (or compatible) ---
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# --- RAG ---
RAG_TOP_K=5
RAG_MIN_SCORE=0.22

# --- Ingest worker ---
INGEST_USE_QUEUE=true
INGEST_JOB_TIMEOUT_SECONDS=600

# --- Rate limits (per user per window) ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_CHAT_PER_WINDOW=20
RATE_LIMIT_INGEST_PER_WINDOW=10
RATE_LIMIT_AGENT_PER_WINDOW=10

# --- Dev helpers on login (NEVER true in production) ---
DEV_MODE=true

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=true
# LOG_JSON=false   # human-readable lines in the terminal

# --- CORS (comma-separated; required for browser UI on another origin) ---
# Local Vite defaults work without this. Production example:
# CORS_ORIGINS=https://sourcebook-peach.vercel.app,http://127.0.0.1:5173,http://localhost:5173
