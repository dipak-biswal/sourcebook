# Copy to apps/api/.env for the API process (do not commit real secrets).

# --- API ---
API_HOST=127.0.0.1
API_PORT=8000

# --- Postgres (use +psycopg for SQLAlchemy 2 + psycopg3) ---
DATABASE_URL=postgresql+psycopg://sourcebook:sourcebook@127.0.0.1:5432/sourcebook
# Windows Docker example:
# DATABASE_URL=postgresql+psycopg://sourcebook:sourcebook@192.168.31.50:5432/sourcebook

# --- Redis (queue + rate limits) ---
REDIS_URL=redis://127.0.0.1:6379/0
# REDIS_URL=redis://192.168.31.50:6379/0

# --- Auth ---
JWT_SECRET=dev-only-change-me-sourcebook

# --- OpenAI (or compatible) ---
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# --- RAG ---
RAG_TOP_K=5
RAG_MIN_SCORE=0.22

# --- Ingest worker ---
INGEST_USE_QUEUE=true
INGEST_JOB_TIMEOUT_SECONDS=600

# --- Rate limits (per user per window) ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_CHAT_PER_WINDOW=20
RATE_LIMIT_INGEST_PER_WINDOW=10
RATE_LIMIT_AGENT_PER_WINDOW=10

# --- Dev helpers on login (NEVER true in production) ---
DEV_MODE=true
